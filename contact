<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HydroStudia | Contact Us</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <header class="navbar" id="navbar"></header>
    <main>
        <section class="contact-page">
            <div class="container">
                <h2 class="section-title" data-key="contact_us">Contact us</h2>
                <div class="contact-wrapper">
                    <div class="contact-form">
                        <form id="contactForm">
                            <div class="form-group"><input type="text" id="contactName" placeholder="Full name" required></div>
                            <div class="form-group"><input type="email" id="contactEmail" placeholder="Email address" required></div>
                            <div class="form-group"><textarea rows="4" id="contactMsg" placeholder="Your message..."></textarea></div>
                            <button type="submit" class="btn-primary"><span data-key="send_message">Send message</span></button>
                        </form>
                    </div>
                    <div class="contact-info">
                        <h3 data-key="reach_us">Reach us directly</h3>
                        <p><i class="fas fa-map-marker-alt"></i> Algiers, Algeria</p>
                        <p><i class="fas fa-phone"></i> +213 778 33 52 82</p>
                        <p><i class="fas fa-envelope"></i> contact@hydrostudia.dz</p>
                        <button class="btn-outline" id="whatsappBtn"><i class="fab fa-whatsapp"></i> WhatsApp</button>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <footer id="footer"></footer>
    <script src="js/main.js"></script>
</body>
</html>
